# OpenRouter API key
OPENROUTER_API_KEY=your_openrouter_api_key_here

# AI Model Selection
# Change these to switch models without touching code
TEXT_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free
VISION_MODEL=google/gemma-4-31b-it:free
AUDIO_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free
VIDEO_MODEL=google/gemma-4-26b-a4b-it:free

# PDF Extraction
# Minimum readable text length before the extractor treats a PDF as digital
PDF_MIN_TEXT_LENGTH=100

# Upload size limit in MB (Vercel/serverless caps ~4MB; raise for local use)
MAX_UPLOAD_MB=4

# OCR Provider Hook
# Currently supported: openrouter
OCR_PROVIDER=openrouter
# OCR model used by the OpenRouter provider
OCR_MODEL=google/gemma-4-31b-it:free

# Server
PORT=3000

# Optional CORS configuration
# Add your frontend origin here if the frontend and backend are hosted separately.
# Example: https://eduai-frontend.onrender.com
CORS_ORIGIN=
